{
  "$schema": "./project.schema.json",
  "project": {
    "name": "（未設定）",
    "localUrl": "http://localhost:8080",
    "devCommand": "npm run dev",
    "adminUrl": "http://localhost:8080/wp-admin/",
    "theme": "development（src/）",
    "productionUrl": "",
    "notes": ""
  },
  "components": [
    {
      "name": "ヘッダー",
      "slug": "header",
      "kind": "layout",
      "bemBlock": "l-header",
      "template": "src/header.php",
      "css": ["src/styles/components/header.css"],
      "figma": { "pc": "", "sp": "" },
      "figmaMeta": { "fileKey": "", "nodeIdPc": "", "nodeIdSp": "" },
      "usedOn": ["all"],
      "status": "未着手"
    },
    {
      "name": "フッター",
      "slug": "footer",
      "kind": "layout",
      "bemBlock": "l-footer",
      "template": "src/footer.php",
      "css": ["src/styles/components/footer.css"],
      "figma": { "pc": "", "sp": "" },
      "figmaMeta": { "fileKey": "", "nodeIdPc": "", "nodeIdSp": "" },
      "usedOn": ["all"],
      "status": "未着手"
    },
    {
      "name": "CTA（例・不要なら削除）",
      "slug": "cta",
      "kind": "part",
      "bemBlock": "c-cta",
      "template": "src/template/parts/c-cta.php",
      "css": ["src/styles/components/cta.css"],
